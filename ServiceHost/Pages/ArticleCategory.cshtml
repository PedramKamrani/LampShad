@page "{id}"
@model ServiceHost.Pages.ArticleCategoryModel
@{
    ViewData["Title"] = "مقالات";
}


<div class="breadcrumb-area section-space--half">
    <div class="container wide">
        <div class="row">
            <div class="col-lg-12">
                <div class="breadcrumb-wrapper breadcrumb-bg">
                    <div class="breadcrumb-content">
                        <h1 class="breadcrumb-content__title">@Model.ArticleCategory.Name</h1>
                        <ul class="breadcrumb-content__page-map">
                            <li>
                                <a asp-page="./Index">صفحه اصلی</a>
                            </li>
                            <li class="active">@Model.ArticleCategory.Name</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @if (Model.ArticleCategory.Articles != null)
    {
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="page-wrapper">
                        <div class="page-content-wrapper">

                            @foreach (var article in Model.ArticleCategory.Articles)
                            {
                                <div class="row">
                                    <div class="col-lg-9 order-1 order-lg-1">
                                        <div class="blog-page-content">
                                            <div class="blog-single-post-container">
                                                
                                                <a asp-page="./Article" asp-route-id="@article.Slug">
                                                    <h3 class="post-title">@article.Title</h3>
                                                    </a>
                                                <div class="post-meta">
                                                    <p>
                                                        <span>
                                                            <i class="fa fa-calendar"></i> نوشته شده در:
                                                            @article.PublishDate
                                                        </span>
                                                    </p>
                                                </div>

                                                <div class="single-blog-post-media">
                                                    <div class="image">
                                                        <img src="~/ProductPictures/@article.Picture" class="img-fluid" alt="@article.PictureAlt" title="@article.Title">
                                                    </div>
                                                </div>

                                                <div class="post-content">
                                                    @Html.Raw(article.Description)
                                                </div>

                                            

                                            
                                            </div>

                                   
                                        </div>
                                    </div>
                                    <div class="col-lg-3 order-2 order-lg-2">
                                        <div class="page-sidebar-wrapper">
                                            <div class="single-sidebar-widget">

                                                <h4 class="single-sidebar-widget__title">گروه مقالات</h4>
                                                <ul class="single-sidebar-widget__category-list">
                                                    @foreach (var category in Model.ArticleCategories)
                                                    {
                                                        <li>
                                                            <a asp-page="./ArticleCategory" asp-route-id="@category.Id" class="active">
                                                                @category.Name <span class="counter">@category.ArticlesCount</span>
                                                            </a>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>

                                        </div>
                                        <!--=======  End of page sidebar wrapper  =======-->
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    <!--=======  End of page wrapper  =======-->
                </div>
            </div>
        </div>
    }
   
</div>

