@page
@{
    Layout = null;
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />

<style>
    /* reset & base */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', 'Tahoma', system-ui, sans-serif;
        background: linear-gradient(145deg, #f5f7fc 0%, #e9ecf3 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    /* کارت اصلی */
    .contact-card {
        max-width: 550px;
        width: 100%;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-radius: 48px 48px 32px 32px;
        box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.25), inset 0 1px 2px rgba(255, 255, 255, 0.7);
        padding: 2rem 1.8rem 2.5rem;
        border: 1px solid rgba(255, 255, 255, 0.4);
        transition: transform 0.2s ease;
    }

        .contact-card:hover {
            transform: translateY(-3px);
        }

    /* هدر */
    .header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 1.8rem;
        border-bottom: 2px dashed #cdd9e9;
        padding-bottom: 1.2rem;
    }

        .header i {
            font-size: 2.4rem;
            color: #1b3a5c;
            background: #d7e3f5;
            padding: 12px;
            border-radius: 30px;
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
        }

        .header h2 {
            font-size: 1.9rem;
            font-weight: 700;
            color: #0a2647;
            letter-spacing: -0.5px;
        }

            .header h2 small {
                font-size: 1rem;
                font-weight: 400;
                color: #2c4c7a;
                display: block;
                margin-top: 4px;
                letter-spacing: 0;
            }

    /* آیتم اطلاعات */
    .info-item {
        display: flex;
        align-items: center;
        gap: 18px;
        background: rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        padding: 18px 20px;
        border-radius: 40px;
        margin-bottom: 18px;
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 6px 14px rgba(0, 20, 40, 0.06);
        transition: all 0.2s;
    }

        .info-item:last-of-type {
            margin-bottom: 28px;
        }

        .info-item:hover {
            background: rgba(255, 255, 255, 0.85);
            border-color: #b7cef0;
            box-shadow: 0 10px 20px -8px rgba(20, 60, 120, 0.15);
        }

    .icon-wrapper {
        width: 48px;
        height: 48px;
        background: #1b3a5c;
        color: white;
        border-radius: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        flex-shrink: 0;
        box-shadow: 0 6px 12px rgba(0, 40, 80, 0.15);
    }

    .info-content {
        flex: 1;
    }

        .info-content .label {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #3f5e7f;
            font-weight: 600;
            opacity: 0.8;
        }

        .info-content .value {
            font-size: 1.3rem;
            font-weight: 600;
            color: #0a1e32;
            margin-top: 2px;
            direction: ltr;
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }

            .info-content .value .persian-text {
                direction: rtl;
                unicode-bidi: embed;
            }

    /* دکمه کپی و تماس */
    .actions {
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 14px;
        margin-top: 10px;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 14px 28px;
        border-radius: 60px;
        font-weight: 600;
        font-size: 1.05rem;
        border: none;
        background: white;
        color: #0a2647;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
        border: 1px solid #ced9ea;
        cursor: pointer;
        transition: 0.15s ease;
        flex: 1 1 auto;
        min-width: 140px;
        text-decoration: none;
        background: #f0f5ff;
    }

    .btn-primary {
        background: #0a2647;
        border: 1px solid #0a2647;
        color: white;
        box-shadow: 0 8px 18px -6px #0a264750;
    }

        .btn-primary i {
            color: white;
        }

        .btn-primary:hover {
            background: #123a62;
            transform: scale(1.02);
            box-shadow: 0 12px 22px -8px #0a264780;
        }

    .btn-outline {
        background: transparent;
        border: 1.5px solid #1f4870;
        color: #1f4870;
    }

        .btn-outline:hover {
            background: #1f487010;
            border-color: #0a2647;
        }

    .btn:active {
        transform: scale(0.96);
    }

    /* پیام کپی */
    .copy-toast {
        text-align: center;
        margin-top: 20px;
        font-size: 0.95rem;
        color: #1b5e3a;
        background: #e3f5e9;
        padding: 8px 16px;
        border-radius: 60px;
        display: inline-block;
        opacity: 0;
        transition: 0.25s;
        border: 1px solid #b2dfc7;
        backdrop-filter: blur(4px);
    }

        .copy-toast.show {
            opacity: 1;
        }

    /* آدرس با فونت فارسی و راست‌چین */
    .address-persian {
        font-family: 'Segoe UI', 'Tahoma', system-ui, sans-serif;
        font-weight: 500;
        font-size: 1.2rem;
        letter-spacing: 0.2px;
        direction: rtl;
        unicode-bidi: embed;
    }

    /* responsive - توجه به @@media به جای @@media */
    @@media (max-width: 480px) {
        .contact-card {
            padding: 1.5rem 1.2rem;
            border-radius: 32px;
        }

        .header h2 {
            font-size: 1.6rem;
        }

        .info-content .value {
            font-size: 1.1rem;
        }

        .btn {
            padding: 12px 18px;
            font-size: 0.95rem;
            min-width: 120px;
        }
    }
</style>

<div class="contact-card">
    <!-- هدر -->
    <div class="header">
        <i class="fas fa-phone-alt"></i>
        <h2>
            تماس با ما
            <small>پاساژ آلومینیوم</small>
        </h2>
    </div>

    <!-- شماره تلفن -->
    <div class="info-item" id="phoneItem">
        <div class="icon-wrapper">
            <i class="fas fa-phone"></i>
        </div>
        <div class="info-content">
            <div class="label">شماره تماس</div>
            <div class="value" dir="ltr">
                <span>۰۹۱۹۴۹۸۰۲۵۵</span>
            </div>
        </div>
    </div>

    <!-- آدرس -->
    <div class="info-item">
        <div class="icon-wrapper">
            <i class="fas fa-map-pin"></i>
        </div>
        <div class="info-content">
            <div class="label">آدرس</div>
            <div class="value address-persian" dir="rtl">
                <span class="persian-text">تهران، پاساژ، آلومینیوم</span>
            </div>
        </div>
    </div>

    <!-- دکمه‌های اقدام -->
    <div class="actions">
        <a href="tel:09194980255" class="btn btn-primary">
            <i class="fas fa-phone-volume"></i> تماس فوری
        </a>
        <button class="btn btn-outline" id="copyBtn">
            <i class="far fa-copy"></i> کپی شماره
        </button>
    </div>

    <!-- پیام کپی -->
    <div id="copyToast" class="copy-toast">
        <i class="fas fa-check-circle" style="margin-left: 8px;"></i> شماره کپی شد!
    </div>

    <!-- توضیح مختصر -->
    <div style="margin-top: 25px; text-align: center; font-size: 0.8rem; color: #3d5e7e; border-top: 1px solid #cfdef0; padding-top: 18px; opacity: 0.8;">
        <i class="fas fa-clock" style="margin-left: 6px;"></i> پاسخگویی ۹ صبح تا ۸ شب
    </div>
</div>

<script>
    (function() {
        const phoneNumber = "09194980255";
        const copyBtn = document.getElementById('copyBtn');
        const toast = document.getElementById('copyToast');

        function showCopyMessage() {
            toast.classList.add('show');
            setTimeout(() => {
                toast.classList.remove('show');
            }, 2500);
        }

        async function copyPhoneNumber() {
            try {
                await navigator.clipboard.writeText(phoneNumber);
                showCopyMessage();
            } catch (err) {
                fallbackCopy(phoneNumber);
            }
        }

        function fallbackCopy(text) {
            const textArea = document.createElement('textarea');
            textArea.value = text;
            textArea.style.position = 'fixed';
            textArea.style.left = '-9999px';
            textArea.style.top = '-9999px';
            document.body.appendChild(textArea);
            textArea.focus();
            textArea.select();
            try {
                const successful = document.execCommand('copy');
                if (successful) {
                    showCopyMessage();
                } else {
                    alert('کپی نشد. لطفاً شماره را دستی کپی کنید: ' + phoneNumber);
                }
            } catch (e) {
                alert('امکان کپی خودکار وجود ندارد. شماره: ' + phoneNumber);
            }
            document.body.removeChild(textArea);
        }

        copyBtn.addEventListener('click', copyPhoneNumber);

        const phoneItem = document.getElementById('phoneItem');
        phoneItem.addEventListener('click', function(e) {
            if (!e.target.closest('a') && !e.target.closest('button')) {
                copyPhoneNumber();
            }
        });

        phoneItem.style.cursor = 'pointer';
        phoneItem.title = 'برای کپی شماره کلیک کنید';
    })();
</script>